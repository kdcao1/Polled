# Firebase Admin service account credentials.
# Create a service account at https://console.cloud.google.com.
# Grant it permission to read Firebase Auth and Firestore for this project.
# Either paste the full JSON as a single-line string:
GOOGLE_SERVICE_ACCOUNT_KEY=
# Or use a local path to the JSON file:
GOOGLE_APPLICATION_CREDENTIALS=

# Optional: require login before viewing the admin dashboard.
# If unset, the dashboard is open on localhost/dev.
ADMIN_SECRET=
