# Google Analytics 4 Property ID (numeric, e.g. 123456789)
# Find it in GA4: Admin → Property Settings → Property ID
GA4_PROPERTY_ID=

# Google Service Account credentials (JSON stringified)
# Create a service account at https://console.cloud.google.com
# Grant it "Viewer" role on your GA4 property
# Then paste the full JSON as a single-line string here
GOOGLE_SERVICE_ACCOUNT_KEY=

# Optional: restrict dashboard access with a simple password
ADMIN_SECRET=
